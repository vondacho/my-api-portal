{
  "kind": "collectionType",
  "collectionName": "specifications",
  "info": {
    "singularName": "specification",
    "pluralName": "specifications",
    "displayName": "Specification"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "specId": {
      "type": "uid",
      "targetField": "",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "productName": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "version": {
      "type": "string",
      "required": true,
      "regex": "^v(0|[1-9]\\d*)$"
    },
    "revision": {
      "type": "string",
      "required": true,
      "unique": false,
      "regex": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "bundleName": {
      "type": "string",
      "required": true
    },
    "componentName": {
      "type": "string"
    },
    "componentRevision": {
      "type": "string",
      "regex": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "contract": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "OPENAPI_V30",
        "OPENAPI_V31",
        "OPENAPI_V32",
        "ASYNCAPI_V2",
        "ASYNCAPI_V3",
        "GRAPHQLS",
        "WSDL_V11",
        "WSDL_V20",
        "OVERLAY_V10",
        "OVERLAY_V11"
      ]
    },
    "body": {
      "type": "json",
      "required": true
    },
    "score": {
      "type": "json"
    },
    "violations": {
      "type": "json"
    }
  }
}
